{
  "_comment": "Example configuration for Scholar Agent. Copy to .lore.json and customize.",

  "knowledge_dir": "../knowledge",
  "index_path": "./indexes/local/index.json",

  "academic": {
    "search": {
      "sources": ["arxiv", "dblp", "semantic_scholar"],
      "default_conferences": [
        "CVPR", "ICCV", "ECCV", "ICLR", "AAAI",
        "NeurIPS", "ICML", "ACL", "EMNLP", "MICCAI"
      ],
      "max_results": 20,
      "date_range_days": 30
    },
    "scoring": {
      "dimensions": ["relevance", "recency", "popularity", "quality"],
      "max_score": 3.0,
      "relevance": {
        "title_keyword_boost": 0.5,
        "summary_keyword_boost": 0.3,
        "category_match_boost": 1.0
      }
    },
    "paper_analysis": {
      "template_languages": ["zh", "en"],
      "note_format": "markdown",
      "frontmatter": true
    },
    "image_extraction": {
      "enabled": true,
      "sources": ["arxiv_source", "pdf_embedded", "pymupdf"],
      "output_subdir": "figures"
    },
    "note_linking": {
      "enabled": true,
      "max_links": 5,
      "min_shared_keywords": 1
    },
    "research_interests": {
      "research_domains": {
        "Machine Learning": {
          "keywords": ["deep learning", "neural network", "transformer", "pre-training", "fine-tuning", "representation learning"],
          "arxiv_categories": ["cs.LG", "cs.AI", "stat.ML"],
          "priority": 5
        },
        "Natural Language Processing": {
          "keywords": ["large language model", "LLM", "NLP", "text generation", "language understanding", "question answering", "RAG"],
          "arxiv_categories": ["cs.CL", "cs.AI"],
          "priority": 5
        }
      },
      "excluded_keywords": ["workshop", "survey"]
    }
  }
}
