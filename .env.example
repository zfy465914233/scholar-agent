# Scholar Agent Environment Variables
# Copy this file to .env and uncomment the variables you need.

# ── Academic Tools ──────────────────────────────────────────────
# Set to 1 to enable academic paper research tools
# LORE_ACADEMIC=1

# Semantic Scholar API key (free: https://api.semanticscholar.org/)
# Improves rate limits for paper search
# S2_API_KEY=

# ── LLM API (for advanced synthesis pipeline) ──────────────────
# Required only if using the full research orchestration pipeline
# LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1

# ── Web Research ────────────────────────────────────────────────
# SearXNG base URL (start with: docker compose up -d)
# SEARXNG_BASE_URL=http://localhost:8080
